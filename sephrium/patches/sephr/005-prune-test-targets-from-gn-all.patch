# Sephr — 005-prune-test-targets-from-gn-all
#
# Sephr ships chrome_framework only — no browser_tests, no unit_tests. The
# stock gn_all target pulls both in, and they transitively reference
# screen_ai and (some) safe_browsing-mode-1 targets that we've gated off
# in our build. Drop them from gn_all so whole-graph `gn gen` resolves.
#
# Also drop the rlz_* targets (ungoogled disable-rlz.patch makes rlz_lib
# empty) and the chrome-internal symupload reference.

--- a/BUILD.gn
+++ b/BUILD.gn
@@ -151,7 +151,9 @@
           "//chrome",
           "//chrome/browser/ui/actions:dump_actions",
           "//chrome/browser/ui/color:dump_colors",
-          "//chrome/test:browser_tests",
+          # Sephr: chrome/test:browser_tests dropped — references mode-0-gated
+          # safe_browsing targets that Sephr's ungoogled patch subset doesn't
+          # fully gate. We only build chrome_framework, not tests.
         ]
       }
       deps += [
@@ -180,7 +182,7 @@
     }
 
     if (!is_ios && !is_castos) {
-      if (!is_fuchsia) {
+      if (false) {  # Sephr: skip chrome/test:unit_tests (mode-0 safe_browsing)
         deps += [ "//chrome/test:unit_tests" ]
       }
       deps += [ "//ui/accessibility:accessibility_unittests" ]
@@ -654,8 +656,8 @@
       # Once this code is in stable, we can land the following CLs to change how
       # symupload is built and run on Mac arm64 official builders, and then this
       # alias can be removed.
-      # Build: https://chrome-internal-review.googlesource.com/c/chrome/src-internal/+/7430844
-      # Run: https://chrome-internal-review.googlesource.com/c/chrome/tools/release/scripts/+/7430843
+      # Build: https://chrome-internal-review.9oo91esource.qjz9zk/c/chrome/src-internal/+/7430844
+      # Run: https://chrome-internal-review.9oo91esource.qjz9zk/c/chrome/tools/release/scripts/+/7430843
       deps += [ "//third_party/breakpad:symupload($host_toolchain)" ]
     }
 
