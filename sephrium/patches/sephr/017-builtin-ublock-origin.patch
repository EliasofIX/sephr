     "//chrome/common:version_header",
+    "//chrome/sephr/builtin_extensions",
     "//chrome/common/net",
     "//chrome/common/notifications",
     "//chrome/installer/util:with_no_strings",
--- a/chrome/browser/extensions/component_extensions_allowlist/allowlist.cc
